# ─── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ────────────────────────────────────────
# Get your free cluster at https://mongodb.com
# Replace <username>, <password>, <cluster> with your values
# ⚠️ If your password contains special chars (@, :, /, ?), URL-encode them (e.g. @ → %40)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Authentication ────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=gnxt_super_secret_2026
JWT_EXPIRES=7d

# ─── CORS ───────────────────────────────────────────
# Comma-separated frontend URLs (no trailing slash)
# For production (Vercel): https://gnxt.vercel.app
# For preview branches (Vercel): https://gnxt-git-*.vercel.app
# For local dev: http://localhost:5173
CORS_ORIGIN=http://localhost:5173,https://gnxt.vercel.app

# ─── SMTP (Support Tickets) ────────────────────────
# Optional — for the /api/support/ticket endpoint
# Use Gmail App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
